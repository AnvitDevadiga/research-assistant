# Required for LLM calls (Groq)
GROQ_API_KEY=your_groq_api_key

# Optional: model id (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# FastAPI CORS (comma-separated origins; default *)
# CORS_ORIGINS=http://localhost:8501

# Streamlit: call remote API instead of in-process graph
# STREAMLIT_USE_API=0
# RESEARCH_API_URL=http://127.0.0.1:8000
